# ============================================================
# AgentSociety mini-reinterpretation — LLM backend configuration
# ============================================================
#
# Two tracks are supported. Pick ONE by setting LLM_BACKEND.
#
#   LLM_BACKEND=gemini          (default) Remote Google Gemini via google-genai SDK
#   LLM_BACKEND=openai_compat   Any OpenAI-compatible endpoint (vLLM / TGI / Ollama /
#                               HuggingFace Inference Providers / Mistral La Plateforme)
#
# Both tracks are BYOK — no key is ever stored server-side.

# Default track: Gemini
LLM_BACKEND=gemini

# === Gemini track ===
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# === OpenAI-compatible track (second / open-source pairing) ===
# Recommended open-weights model for research reproduction (Apache 2.0, Korean supported):
#   mistralai/Mistral-Small-3.1-24B-Instruct-2503
# Alternatives: openai/gpt-oss-120b, meta-llama/Llama-3.3-70B-Instruct
#
# Example endpoints:
#   https://router.huggingface.co/v1           (HF Inference Providers — exclude Z.ai in settings)
#   https://api.mistral.ai/v1                  (Mistral La Plateforme)
#   http://localhost:8000/v1                   (self-hosted vLLM)
#   http://localhost:11434/v1                  (Ollama)
#
# LLM_API_KEY=your-openai-compatible-key
# LLM_API_BASE=https://router.huggingface.co/v1
# LLM_MODEL=mistralai/Mistral-Small-3.1-24B-Instruct-2503

# === Telemetry (disable third-party usage reporting) ===
ANONYMIZED_TELEMETRY=False
